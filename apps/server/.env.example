# Agent Kit Admin - Server 环境变量示例
# 复制此文件为 .env 并修改配置

# 应用
APP_NAME=Agent Kit Admin
APP_VERSION=0.1.0
DEBUG=true

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=agentkit
DB_PASSWORD=agentkit_dev_2024
DB_NAME=agentkit

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_2024
MINIO_BUCKET=packages
MINIO_SECURE=false

# JWT (生产环境必须修改!)
JWT_SECRET=agent-kit-jwt-secret-key-change-in-production-2024
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# OAuth - 启用的 IM 提供商（wechat_work / feishu / dingtalk）
# 设置后登录页只显示对应的 IM 图标，留空则显示所有已配置的提供商
OAUTH_PROVIDER=

# OAuth - 企业微信
WECHAT_WORK_CORP_ID=
WECHAT_WORK_SECRET=
WECHAT_WORK_AGENT_ID=

# OAuth - 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# OAuth - 钉钉
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
