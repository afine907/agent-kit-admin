{
  "name": "agent-kit-admin",
  "private": true,
  "scripts": {
    "dev:server": "cd apps/server && python -m uvicorn app.main:app --reload",
    "dev:cli": "cd apps/cli && pnpm dev",
    "dev:web": "cd apps/web && pnpm dev",
    "build:cli": "cd apps/cli && pnpm build",
    "build:web": "cd apps/web && pnpm build",
    "lint": "pnpm lint:web && pnpm lint:cli",
    "lint:web": "oxlint apps/web",
    "lint:cli": "oxlint apps/cli",
    "typecheck": "cd apps/cli && pnpm typecheck & cd apps/web && pnpm typecheck"
  },
  "devDependencies": {
    "oxlint": "^1.69.0"
  }
}
