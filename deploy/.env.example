# Agent Kit Admin - 生产环境变量模板
# 复制此文件为 .env 并修改配置

# ============================================
# 数据库配置
# ============================================
DB_USER=agentkit
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=agentkit

# ============================================
# MinIO 配置
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# JWT 配置 (必须修改! >= 32 字符)
# ============================================
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# ============================================
# OAuth 配置
# ============================================

# 企业微信
WECCHAT_WORK_CORP_ID=
WECCHAT_WORK_SECRET=
WECCHAT_WORK_AGENT_ID=

# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 钉钉
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
